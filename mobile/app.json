{
  "expo": {
    "name": "News Reels",
    "slug": "news-reels",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "newsreels",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.25"
          }
        }
      ],
      "./plugins/withKotlinVersion"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0f"
      },
      "package": "com.vibha.newsreels"
    },
    "ios": {
      "supportsTablet": false
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "fd2f9dc1-55b5-4b88-83e1-dac554a286f0"
      }
    }
  }
}
