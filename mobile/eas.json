{
  "cli": {
    "version": ">= 18.0.0"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk",
        "env": {
          "EXPO_NO_BUNDLE_SPLITTING": "1"
        }
      },
      "env": {
        "EXPO_USE_HERMES": "1"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
